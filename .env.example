# =============================================================
# LiveMart MSA — 환경 변수 템플릿
# 이 파일을 .env 로 복사 후 실제 값으로 채워 사용하세요
# 절대 .env 파일을 git에 커밋하지 마세요
# =============================================================

# ── 공통 인프라 ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans

CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── User Service ─────────────────────────────────────────────
USER_DB_HOST=localhost
USER_DB_PORT=5434
USER_DB_USERNAME=userapp
USER_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT — 최소 256비트(32바이트) 이상의 랜덤 값 필요
# 생성 예: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_MINIMUM_256_BIT_RANDOM_VALUE

# OAuth2
KAKAO_CLIENT_ID=CHANGE_ME
KAKAO_CLIENT_SECRET=CHANGE_ME
NAVER_CLIENT_ID=CHANGE_ME
NAVER_CLIENT_SECRET=CHANGE_ME
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

OAUTH2_BASE_URL=http://localhost:8080
OAUTH2_REDIRECT_URI=http://localhost:3000/auth/callback

# 이메일 (Naver SMTP 또는 다른 SMTP)
SMTP_USERNAME=your-email@naver.com
SMTP_PASSWORD=CHANGE_ME

# ── Order Service ─────────────────────────────────────────────
ORDER_DB_HOST=localhost
ORDER_DB_PORT=5436
ORDER_DB_USERNAME=orderapp
ORDER_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Payment Service ───────────────────────────────────────────
PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=5437
PAYMENT_DB_USERNAME=paymentapp
PAYMENT_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Toss Payments — https://developers.tosspayments.com 에서 발급
TOSS_CLIENT_KEY=CHANGE_ME
TOSS_SECRET_KEY=CHANGE_ME

# ── Product Service ───────────────────────────────────────────
PRODUCT_DB_HOST=localhost
PRODUCT_DB_PORT=5435
PRODUCT_DB_USERNAME=productapp
PRODUCT_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Inventory Service ─────────────────────────────────────────
INVENTORY_DB_HOST=localhost
INVENTORY_DB_PORT=5438
INVENTORY_DB_USERNAME=inventoryapp
INVENTORY_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Analytics Service ─────────────────────────────────────────
ANALYTICS_DB_HOST=localhost
ANALYTICS_DB_PORT=5439
ANALYTICS_DB_USERNAME=analyticsapp
ANALYTICS_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
API_GATEWAY_URL=http://api-gateway:8080

# ── Docker Compose 인프라 비밀번호 (docker-compose.yml 참고) ──
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
USER_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PRODUCT_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ORDER_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PAYMENT_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── 모니터링 ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GRAFANA_SECRET_KEY=CHANGE_ME

# ── 쿠키 보안 (로컬 개발: false, HTTPS 프로덕션: true) ────────
COOKIE_SECURE=false
