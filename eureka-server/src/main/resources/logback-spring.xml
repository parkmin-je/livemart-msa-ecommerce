<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Spring Boot %clr/%wEx 컨버터 명시적 등록 (logstash-logback-encoder 초기화 순서 충돌 방지) -->
    <conversionRule conversionWord="clr" converterClass="org.springframework.boot.logging.logback.ColorConverter"/>
    <conversionRule conversionWord="wEx" converterClass="org.springframework.boot.logging.logback.ExtendedWhitespaceThrowableProxyConverter"/>

    <springProperty scope="context" name="SERVICE_NAME" source="spring.application.name" defaultValue="eureka-server"/>
    <springProperty scope="context" name="ACTIVE_PROFILE" source="spring.profiles.active" defaultValue="default"/>

    <!-- ── 콘솔: 개발 환경 ─────────────────────────────────────── -->
    <springProfile name="local,default">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%clr(%d{HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <!-- Eureka 서버 노이즈 억제 (등록/해제 heartbeat) -->
        <logger name="com.netflix.eureka" level="WARN"/>
        <logger name="com.netflix.discovery" level="WARN"/>
        <logger name="org.springframework.cloud.netflix.eureka" level="WARN"/>
    </springProfile>

    <!-- ── JSON 구조화 로그: 운영 환경 ─────────────────────────── -->
    <springProfile name="k8s,prod,staging">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeCallerData>false</includeCallerData>
                <fieldNames>
                    <timestamp>time</timestamp>
                    <version>[ignore]</version>
                    <levelValue>[ignore]</levelValue>
                </fieldNames>
                <customFields>{"service":"${SERVICE_NAME}","env":"${ACTIVE_PROFILE}"}</customFields>
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>spanId</includeMdcKeyName>
                <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxDepthPerCause>10</maxDepthPerCause>
                    <rootCauseFirst>true</rootCauseFirst>
                </throwableConverter>
            </encoder>
        </appender>

        <appender name="ASYNC_JSON" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="JSON_CONSOLE"/>
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
        </appender>

        <root level="INFO">
            <appender-ref ref="ASYNC_JSON"/>
        </root>

        <!-- Eureka heartbeat 로그 억제 (운영 환경에서 매 30초 노이즈) -->
        <logger name="com.netflix.eureka" level="WARN"/>
        <logger name="com.netflix.discovery" level="WARN"/>
        <logger name="org.springframework.cloud.netflix" level="WARN"/>
        <logger name="org.springframework" level="WARN"/>
    </springProfile>
</configuration>
